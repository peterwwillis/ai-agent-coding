# Caddy reverse-proxy – environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env && $EDITOR .env
#
# NEVER commit .env to version control – it is listed in .gitignore.
#
# Caddy substitutes {$VAR} and {$VAR:default} placeholders in the Caddyfile
# at startup using these environment variables. No secrets are hard-coded in
# the Caddyfile.
#
# ============================================================================
# Basic-auth credentials
# ============================================================================
# Username for the protected routes (n8n, terminal, code, vnc).
PROXY_AUTH_USER=admin

# Bcrypt hash of the password (single $ signs).
# Generate with:  make gen-hash
# Then paste the "Caddy format" line (single $) here.
#
# To load from an external secrets manager instead of storing here, leave this
# blank and export the variable before running make:
#   export PROXY_AUTH_HASH="$(vault kv get -field=hash secret/proxy-auth)"
#   make up
PROXY_AUTH_HASH=

# ============================================================================
# TLS / domain settings
# ============================================================================
# Hostname used in the Caddyfile site block (matches your browser URL).
# Examples: mac.local | myhost.local | 192.168.1.50
PROXY_DOMAIN=mac.local
